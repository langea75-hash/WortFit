<!doctype html><html lang="de"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>WortFit One 1.3 Lite</title>
<style>
:root{--bg:#eef3f8;--card:#fff;--text:#172033;--muted:#64748b;--primary:#2563eb;--border:#dbe3ee}*{box-sizing:border-box}body{margin:0;font-family:Arial,sans-serif;background:var(--bg);color:var(--text)}.app{max-width:800px;margin:auto;padding:18px}header{display:flex;justify-content:space-between;align-items:center}h1{font-size:42px}.badge{background:#dbeafe;color:#1e40af;padding:8px 12px;border-radius:999px;font-weight:700}.card{background:#fff;border:1px solid var(--border);border-radius:22px;padding:18px;box-shadow:0 8px 24px #0001}.view{display:none}.view.active{display:block}.menu,.buttons{display:grid;grid-template-columns:1fr 1fr;gap:12px}button{border:0;border-radius:15px;padding:15px;font-size:18px;font-weight:700;cursor:pointer}.primary{background:#2563eb;color:#fff}.good{background:#dcfce7;color:#166534}.secondary{background:#e2e8f0;color:#1e293b}.image{max-width:560px;margin:auto}.image svg{width:100%;height:auto}.word{font-size:52px;text-align:center;font-weight:800}textarea{width:100%;min-height:90px;border:2px solid var(--border);border-radius:16px;padding:14px;font-size:20px}.feedback,.example,.waitbox{margin-top:12px;padding:14px;border-radius:15px;border:1px solid var(--border);font-size:18px}.example{display:none;background:#eff6ff}.waitbox{background:#fff7ed}.count{font-size:32px;font-weight:800;text-align:center;color:#b45309}.stats{display:flex;justify-content:space-between;margin-top:12px;color:var(--muted);font-weight:700}select{font-size:18px;padding:10px;border-radius:12px}@media(max-width:560px){.menu,.buttons{grid-template-columns:1fr}}
</style></head><body><div class="app"><header><h1>WortFit</h1><div class="badge">One 1.3 Lite</div></header>
<section id="home" class="view active"><div class="card"><h2>Was möchtest du üben?</h2><div class="menu"><button class="primary" onclick="show('word')">🖼️ Worttraining</button><button class="good" onclick="show('free')">✍️ Eigenen Satz bilden</button></div></div></section>
<section id="word" class="view"><button class="secondary" onclick="show('home')">← Menü</button><div class="card"><div><b>Wartezeit:</b> <select id="wait"><option>5</option><option selected>10</option><option>15</option></select> Sekunden <button class="secondary" id="start">⏳ Start</button></div><div class="image" id="image"></div><div class="word" id="wordText" style="visibility:hidden"></div><div style="text-align:center;font-size:24px;font-weight:bold;margin:12px 0">✍️ Bilde einen Satz mit dem Wort.</div><div class="waitbox">Erst nachdenken und einen Satz überlegen.<div class="count" id="count">Bereit</div></div><button class="secondary" id="exampleBtn" style="width:100%">💬 Beispiel zeigen</button><div class="example" id="example"></div><h3>Satz schreiben oder sprechen</h3><textarea id="sentence" placeholder="Schreibe oder sprich deinen Satz ..."></textarea><div class="buttons"><button class="primary" id="speak">🎤 Sprechen</button><button class="good" id="check">✓ Satz prüfen</button><button class="secondary" id="read">🔊 Vorlesen</button><button class="secondary" id="next">Nächstes Wort →</button></div><div class="feedback" id="feedback">Drücke auf „Start“.</div><div class="stats"><span>Bearbeitet: <b id="done">0</b></span><span>Gut gelungen: <b id="goodCount">0</b></span></div></div></section>
<section id="free" class="view"><button class="secondary" onclick="show('home')">← Menü</button><div class="card"><h2>✍️ Eigenen Satz bilden</h2><textarea id="freeSentence" placeholder="Mein eigener Satz ..."></textarea><div class="buttons"><button class="primary" id="freeSpeak">🎤 Sprechen</button><button class="good" id="freeCheck">✓ Satz prüfen</button><button class="secondary" id="freeRead">🔊 Vorlesen</button><button class="secondary" id="freeClear">🗑️ Löschen</button></div><div class="feedback" id="freeFeedback">Bilde deinen eigenen Satz.</div></div></section>
</div><script>
const items=[{"word": "Hund", "example": "Der Hund läuft im Garten.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Hund\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<ellipse cx=\"175\" cy=\"135\" rx=\"70\" ry=\"42\" fill=\"#c98b4f\"/>\n<circle cx=\"115\" cy=\"105\" r=\"38\" fill=\"#d79b60\"/>\n<ellipse cx=\"92\" cy=\"82\" rx=\"13\" ry=\"25\" fill=\"#8b5e34\" transform=\"rotate(-25 92 82)\"/>\n<ellipse cx=\"138\" cy=\"82\" rx=\"13\" ry=\"25\" fill=\"#8b5e34\" transform=\"rotate(25 138 82)\"/>\n<circle cx=\"104\" cy=\"102\" r=\"4\" fill=\"#111827\"/><circle cx=\"126\" cy=\"102\" r=\"4\" fill=\"#111827\"/>\n<ellipse cx=\"115\" cy=\"116\" rx=\"10\" ry=\"7\" fill=\"#111827\"/>\n<rect x=\"130\" y=\"166\" width=\"16\" height=\"28\" rx=\"8\" fill=\"#8b5e34\"/>\n<rect x=\"190\" y=\"166\" width=\"16\" height=\"28\" rx=\"8\" fill=\"#8b5e34\"/>\n<path d=\"M240 125 Q280 100 274 72\" fill=\"none\" stroke=\"#8b5e34\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Hund</text>\n    </svg>"}, {"word": "Katze", "example": "Die Katze sitzt auf dem Sofa.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Katze\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<ellipse cx=\"180\" cy=\"138\" rx=\"58\" ry=\"45\" fill=\"#9ca3af\"/>\n<circle cx=\"128\" cy=\"105\" r=\"38\" fill=\"#b8bec8\"/>\n<polygon points=\"100,80 112,47 128,80\" fill=\"#9ca3af\"/>\n<polygon points=\"128,80 148,48 156,83\" fill=\"#9ca3af\"/>\n<circle cx=\"117\" cy=\"104\" r=\"4\" fill=\"#111827\"/><circle cx=\"139\" cy=\"104\" r=\"4\" fill=\"#111827\"/>\n<polygon points=\"128,113 121,120 135,120\" fill=\"#f59e9e\"/>\n<path d=\"M95 120 L55 112 M96 128 L52 130 M160 120 L205 112 M160 128 L205 132\" stroke=\"#4b5563\" stroke-width=\"3\"/>\n<path d=\"M230 145 Q290 115 270 68\" fill=\"none\" stroke=\"#9ca3af\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Katze</text>\n    </svg>"}, {"word": "Vogel", "example": "Der Vogel fliegt über das Haus.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Vogel\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<ellipse cx=\"180\" cy=\"125\" rx=\"58\" ry=\"42\" fill=\"#60a5fa\"/>\n<circle cx=\"135\" cy=\"103\" r=\"30\" fill=\"#93c5fd\"/>\n<polygon points=\"105,103 72,92 103,119\" fill=\"#f59e0b\"/>\n<circle cx=\"128\" cy=\"98\" r=\"4\" fill=\"#111827\"/>\n<path d=\"M180 125 Q205 82 236 108 Q210 137 180 125\" fill=\"#2563eb\"/>\n<polygon points=\"226,126 275,106 247,140\" fill=\"#3b82f6\"/>\n<line x1=\"165\" y1=\"164\" x2=\"155\" y2=\"188\" stroke=\"#92400e\" stroke-width=\"5\"/>\n<line x1=\"195\" y1=\"164\" x2=\"205\" y2=\"188\" stroke=\"#92400e\" stroke-width=\"5\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Vogel</text>\n    </svg>"}, {"word": "Pferd", "example": "Das Pferd steht auf der Wiese.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Pferd\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<ellipse cx=\"190\" cy=\"133\" rx=\"75\" ry=\"42\" fill=\"#a16207\"/>\n<rect x=\"116\" y=\"80\" width=\"45\" height=\"80\" rx=\"20\" fill=\"#b7791f\" transform=\"rotate(-18 138 120)\"/>\n<ellipse cx=\"122\" cy=\"75\" rx=\"32\" ry=\"24\" fill=\"#b7791f\" transform=\"rotate(-12 122 75)\"/>\n<polygon points=\"105,56 112,34 120,60\" fill=\"#92400e\"/><polygon points=\"132,57 143,36 145,65\" fill=\"#92400e\"/>\n<circle cx=\"112\" cy=\"72\" r=\"4\" fill=\"#111827\"/>\n<rect x=\"150\" y=\"163\" width=\"14\" height=\"34\" rx=\"6\" fill=\"#78350f\"/>\n<rect x=\"214\" y=\"163\" width=\"14\" height=\"34\" rx=\"6\" fill=\"#78350f\"/>\n<path d=\"M262 125 Q300 142 290 180\" fill=\"none\" stroke=\"#78350f\" stroke-width=\"12\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Pferd</text>\n    </svg>"}, {"word": "Apfel", "example": "Ich esse einen roten Apfel.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Apfel\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<path d=\"M180 72 C130 42 92 90 110 145 C125 188 168 187 180 169 C192 187 235 188 250 145 C268 90 230 42 180 72Z\" fill=\"#ef4444\"/>\n<rect x=\"174\" y=\"42\" width=\"12\" height=\"38\" rx=\"6\" fill=\"#7c2d12\" transform=\"rotate(10 180 60)\"/>\n<ellipse cx=\"205\" cy=\"51\" rx=\"30\" ry=\"13\" fill=\"#22c55e\" transform=\"rotate(-18 205 51)\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Apfel</text>\n    </svg>"}, {"word": "Brot", "example": "Das Brot liegt auf dem Tisch.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Brot\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<path d=\"M90 150 Q88 85 145 74 Q178 38 217 74 Q275 84 270 150 Q268 180 235 184 L125 184 Q92 180 90 150Z\" fill=\"#d9a45b\"/>\n<path d=\"M135 87 Q145 115 137 142 M180 72 Q190 106 180 139 M225 86 Q232 114 222 143\" fill=\"none\" stroke=\"#f5d08b\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Brot</text>\n    </svg>"}, {"word": "Kaffee", "example": "Ich trinke morgens Kaffee.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Kaffee\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"105\" y=\"85\" width=\"135\" height=\"90\" rx=\"18\" fill=\"#e5e7eb\" stroke=\"#64748b\" stroke-width=\"5\"/>\n<path d=\"M240 105 Q292 102 286 138 Q280 168 240 158\" fill=\"none\" stroke=\"#64748b\" stroke-width=\"10\"/>\n<ellipse cx=\"172\" cy=\"100\" rx=\"55\" ry=\"14\" fill=\"#6b3f24\"/>\n<path d=\"M145 70 Q130 48 148 30 M180 70 Q166 46 183 27 M214 70 Q200 48 217 30\" fill=\"none\" stroke=\"#94a3b8\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Kaffee</text>\n    </svg>"}, {"word": "Banane", "example": "Die Banane ist gelb.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Banane\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<path d=\"M92 88 Q132 184 238 174 Q282 170 294 127 Q258 156 213 150 Q141 140 117 72Z\" fill=\"#facc15\" stroke=\"#ca8a04\" stroke-width=\"5\"/>\n<rect x=\"104\" y=\"61\" width=\"17\" height=\"28\" rx=\"6\" fill=\"#7c5a12\" transform=\"rotate(-18 112 75)\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Banane</text>\n    </svg>"}, {"word": "Haus", "example": "Das Haus hat ein rotes Dach.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Haus\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"105\" y=\"105\" width=\"150\" height=\"92\" rx=\"4\" fill=\"#fde68a\"/>\n<polygon points=\"85,112 180,42 275,112\" fill=\"#dc2626\"/>\n<rect x=\"162\" y=\"140\" width=\"38\" height=\"57\" fill=\"#92400e\"/>\n<rect x=\"120\" y=\"128\" width=\"30\" height=\"30\" fill=\"#bfdbfe\" stroke=\"#475569\" stroke-width=\"4\"/>\n<rect x=\"213\" y=\"128\" width=\"30\" height=\"30\" fill=\"#bfdbfe\" stroke=\"#475569\" stroke-width=\"4\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Haus</text>\n    </svg>"}, {"word": "Krankenhaus", "example": "Das Krankenhaus ist groß.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Krankenhaus\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"85\" y=\"62\" width=\"190\" height=\"135\" rx=\"8\" fill=\"#e5e7eb\" stroke=\"#64748b\" stroke-width=\"4\"/>\n<rect x=\"158\" y=\"70\" width=\"44\" height=\"44\" rx=\"4\" fill=\"#fff\"/>\n<rect x=\"175\" y=\"77\" width=\"10\" height=\"30\" fill=\"#ef4444\"/><rect x=\"165\" y=\"87\" width=\"30\" height=\"10\" fill=\"#ef4444\"/>\n<rect x=\"115\" y=\"126\" width=\"28\" height=\"28\" fill=\"#bfdbfe\"/><rect x=\"217\" y=\"126\" width=\"28\" height=\"28\" fill=\"#bfdbfe\"/>\n<rect x=\"160\" y=\"145\" width=\"40\" height=\"52\" fill=\"#94a3b8\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Krankenhaus</text>\n    </svg>"}, {"word": "Schule", "example": "Die Kinder gehen zur Schule.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Schule\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"92\" y=\"90\" width=\"176\" height=\"108\" rx=\"5\" fill=\"#fef3c7\"/>\n<polygon points=\"80,96 180,45 280,96\" fill=\"#b45309\"/>\n<rect x=\"160\" y=\"140\" width=\"40\" height=\"58\" fill=\"#78350f\"/>\n<rect x=\"112\" y=\"118\" width=\"30\" height=\"30\" fill=\"#bfdbfe\"/><rect x=\"218\" y=\"118\" width=\"30\" height=\"30\" fill=\"#bfdbfe\"/>\n<rect x=\"138\" y=\"67\" width=\"84\" height=\"24\" rx=\"5\" fill=\"#fff\"/><text x=\"180\" y=\"84\" text-anchor=\"middle\" font-size=\"18\" font-family=\"Arial\" font-weight=\"700\">SCHULE</text>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Schule</text>\n    </svg>"}, {"word": "Garten", "example": "Im Garten wachsen Blumen.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Garten\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"0\" y=\"160\" width=\"360\" height=\"45\" fill=\"#86efac\"/>\n<path d=\"M35 165 Q60 110 88 165 M85 165 Q110 95 140 165 M220 165 Q245 100 275 165 M275 165 Q305 115 330 165\" fill=\"#22c55e\"/>\n<circle cx=\"78\" cy=\"120\" r=\"15\" fill=\"#f472b6\"/><circle cx=\"132\" cy=\"110\" r=\"15\" fill=\"#facc15\"/><circle cx=\"270\" cy=\"120\" r=\"15\" fill=\"#60a5fa\"/>\n<rect x=\"173\" y=\"100\" width=\"14\" height=\"65\" fill=\"#92400e\"/><circle cx=\"180\" cy=\"83\" r=\"43\" fill=\"#4ade80\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Garten</text>\n    </svg>"}, {"word": "Fahrrad", "example": "Ich fahre mit dem Fahrrad.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Fahrrad\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<circle cx=\"105\" cy=\"158\" r=\"42\" fill=\"none\" stroke=\"#334155\" stroke-width=\"7\"/>\n<circle cx=\"255\" cy=\"158\" r=\"42\" fill=\"none\" stroke=\"#334155\" stroke-width=\"7\"/>\n<path d=\"M105 158 L152 105 L190 158 L135 158 L170 95 L230 95 L255 158 M152 105 L128 90\" fill=\"none\" stroke=\"#2563eb\" stroke-width=\"8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n<line x1=\"220\" y1=\"88\" x2=\"244\" y2=\"73\" stroke=\"#334155\" stroke-width=\"6\"/>\n<line x1=\"119\" y1=\"87\" x2=\"142\" y2=\"87\" stroke=\"#334155\" stroke-width=\"6\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Fahrrad</text>\n    </svg>"}, {"word": "Auto", "example": "Das Auto steht vor dem Haus.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Auto\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<path d=\"M80 145 L105 100 Q116 82 140 82 H220 Q244 82 255 100 L280 145 V175 H80Z\" fill=\"#3b82f6\"/>\n<path d=\"M130 93 H225 L244 130 H112Z\" fill=\"#bfdbfe\"/>\n<circle cx=\"125\" cy=\"174\" r=\"24\" fill=\"#1f2937\"/><circle cx=\"235\" cy=\"174\" r=\"24\" fill=\"#1f2937\"/>\n<circle cx=\"125\" cy=\"174\" r=\"10\" fill=\"#9ca3af\"/><circle cx=\"235\" cy=\"174\" r=\"10\" fill=\"#9ca3af\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Auto</text>\n    </svg>"}, {"word": "Bus", "example": "Der Bus fährt in die Stadt.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Bus\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"70\" y=\"65\" width=\"220\" height=\"120\" rx=\"18\" fill=\"#f59e0b\"/>\n<rect x=\"90\" y=\"82\" width=\"180\" height=\"55\" rx=\"8\" fill=\"#dbeafe\"/>\n<line x1=\"145\" y1=\"82\" x2=\"145\" y2=\"137\" stroke=\"#64748b\" stroke-width=\"5\"/><line x1=\"210\" y1=\"82\" x2=\"210\" y2=\"137\" stroke=\"#64748b\" stroke-width=\"5\"/>\n<circle cx=\"115\" cy=\"185\" r=\"23\" fill=\"#1f2937\"/><circle cx=\"245\" cy=\"185\" r=\"23\" fill=\"#1f2937\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Bus</text>\n    </svg>"}, {"word": "Zug", "example": "Der Zug kommt am Bahnhof an.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Zug\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"85\" y=\"65\" width=\"190\" height=\"120\" rx=\"28\" fill=\"#ef4444\"/>\n<rect x=\"110\" y=\"82\" width=\"140\" height=\"55\" rx=\"10\" fill=\"#dbeafe\"/>\n<line x1=\"180\" y1=\"82\" x2=\"180\" y2=\"137\" stroke=\"#64748b\" stroke-width=\"5\"/>\n<circle cx=\"130\" cy=\"175\" r=\"18\" fill=\"#1f2937\"/><circle cx=\"230\" cy=\"175\" r=\"18\" fill=\"#1f2937\"/>\n<line x1=\"80\" y1=\"198\" x2=\"280\" y2=\"198\" stroke=\"#475569\" stroke-width=\"7\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Zug</text>\n    </svg>"}, {"word": "Frau", "example": "Die Frau kauft neue Schuhe.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Frau\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<circle cx=\"180\" cy=\"82\" r=\"38\" fill=\"#f3c6a5\"/>\n<path d=\"M141 78 Q145 35 180 35 Q218 35 220 84 Q198 58 154 67Z\" fill=\"#7c3f20\"/>\n<path d=\"M130 195 Q132 125 180 120 Q228 125 230 195Z\" fill=\"#a78bfa\"/>\n<circle cx=\"166\" cy=\"82\" r=\"4\" fill=\"#111827\"/><circle cx=\"194\" cy=\"82\" r=\"4\" fill=\"#111827\"/>\n<path d=\"M166 102 Q180 112 194 102\" fill=\"none\" stroke=\"#9f1239\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Frau</text>\n    </svg>"}, {"word": "Mann", "example": "Der Mann liest eine Zeitung.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Mann\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<circle cx=\"180\" cy=\"82\" r=\"38\" fill=\"#d6a57a\"/>\n<path d=\"M144 72 Q150 35 180 35 Q211 35 217 72 Q185 52 144 72Z\" fill=\"#3f2a1d\"/>\n<path d=\"M128 195 Q130 125 180 120 Q230 125 232 195Z\" fill=\"#60a5fa\"/>\n<circle cx=\"166\" cy=\"82\" r=\"4\" fill=\"#111827\"/><circle cx=\"194\" cy=\"82\" r=\"4\" fill=\"#111827\"/>\n<path d=\"M166 103 Q180 110 194 103\" fill=\"none\" stroke=\"#7c2d12\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Mann</text>\n    </svg>"}, {"word": "Kind", "example": "Das Kind spielt mit dem Ball.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Kind\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<circle cx=\"180\" cy=\"86\" r=\"34\" fill=\"#f2c29f\"/>\n<path d=\"M148 78 Q155 48 180 48 Q205 48 212 78 Q185 63 148 78Z\" fill=\"#a16207\"/>\n<path d=\"M137 195 Q140 125 180 122 Q220 125 223 195Z\" fill=\"#34d399\"/>\n<circle cx=\"168\" cy=\"86\" r=\"4\" fill=\"#111827\"/><circle cx=\"192\" cy=\"86\" r=\"4\" fill=\"#111827\"/>\n<path d=\"M167 104 Q180 115 193 104\" fill=\"none\" stroke=\"#9f1239\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n<circle cx=\"270\" cy=\"155\" r=\"28\" fill=\"#f97316\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Kind</text>\n    </svg>"}, {"word": "Arzt", "example": "Der Arzt untersucht den Patienten.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Arzt\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<circle cx=\"180\" cy=\"72\" r=\"34\" fill=\"#e0b18b\"/>\n<path d=\"M145 62 Q152 35 180 35 Q208 35 215 62\" fill=\"#4b5563\"/>\n<path d=\"M120 198 Q125 118 180 113 Q235 118 240 198Z\" fill=\"#ffffff\" stroke=\"#cbd5e1\" stroke-width=\"4\"/>\n<path d=\"M180 113 V198\" stroke=\"#cbd5e1\" stroke-width=\"4\"/>\n<path d=\"M155 120 Q140 155 160 170 Q180 185 200 170 Q220 155 205 120\" fill=\"none\" stroke=\"#475569\" stroke-width=\"5\"/>\n<circle cx=\"160\" cy=\"171\" r=\"8\" fill=\"#64748b\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Arzt</text>\n    </svg>"}, {"word": "Ball", "example": "Der Ball liegt auf dem Boden.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Ball\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<circle cx=\"180\" cy=\"125\" r=\"70\" fill=\"#ffffff\" stroke=\"#1f2937\" stroke-width=\"6\"/>\n<polygon points=\"180,88 205,105 196,135 164,135 155,105\" fill=\"#1f2937\"/>\n<path d=\"M180 55 L180 88 M113 91 L155 105 M247 91 L205 105 M136 184 L164 135 M224 184 L196 135\" stroke=\"#1f2937\" stroke-width=\"6\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Ball</text>\n    </svg>"}, {"word": "Tasse", "example": "Die Tasse steht auf dem Tisch.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Tasse\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"105\" y=\"80\" width=\"135\" height=\"100\" rx=\"18\" fill=\"#f1f5f9\" stroke=\"#64748b\" stroke-width=\"5\"/>\n<path d=\"M240 105 Q292 102 286 142 Q280 173 240 162\" fill=\"none\" stroke=\"#64748b\" stroke-width=\"10\"/>\n<path d=\"M140 66 Q126 42 145 25 M180 66 Q166 40 183 22 M220 66 Q205 43 223 25\" fill=\"none\" stroke=\"#94a3b8\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Tasse</text>\n    </svg>"}, {"word": "Schlüssel", "example": "Der Schlüssel liegt neben der Tür.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Schlüssel\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<circle cx=\"120\" cy=\"115\" r=\"42\" fill=\"none\" stroke=\"#f59e0b\" stroke-width=\"18\"/>\n<line x1=\"150\" y1=\"145\" x2=\"255\" y2=\"185\" stroke=\"#f59e0b\" stroke-width=\"18\" stroke-linecap=\"round\"/>\n<line x1=\"220\" y1=\"171\" x2=\"238\" y2=\"145\" stroke=\"#f59e0b\" stroke-width=\"14\"/>\n<line x1=\"245\" y1=\"181\" x2=\"262\" y2=\"158\" stroke=\"#f59e0b\" stroke-width=\"14\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Schlüssel</text>\n    </svg>"}, {"word": "Telefon", "example": "Das Telefon klingelt laut.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Telefon\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"125\" y=\"45\" width=\"110\" height=\"150\" rx=\"20\" fill=\"#1f2937\"/>\n<rect x=\"137\" y=\"62\" width=\"86\" height=\"105\" rx=\"8\" fill=\"#dbeafe\"/>\n<circle cx=\"180\" cy=\"181\" r=\"8\" fill=\"#94a3b8\"/>\n<path d=\"M145 100 Q180 75 215 100 Q205 135 180 145 Q155 135 145 100Z\" fill=\"#22c55e\"/>\n<path d=\"M168 102 Q174 117 189 124\" fill=\"none\" stroke=\"#fff\" stroke-width=\"7\" stroke-linecap=\"round\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Telefon</text>\n    </svg>"}, {"word": "Bett", "example": "Das Bett steht im Schlafzimmer.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Bett\">\n    <rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/>\n    \n<rect x=\"70\" y=\"120\" width=\"220\" height=\"65\" rx=\"8\" fill=\"#60a5fa\"/>\n<rect x=\"70\" y=\"78\" width=\"28\" height=\"108\" rx=\"8\" fill=\"#475569\"/>\n<rect x=\"98\" y=\"95\" width=\"90\" height=\"42\" rx=\"18\" fill=\"#f8fafc\"/>\n<rect x=\"188\" y=\"95\" width=\"102\" height=\"42\" rx=\"8\" fill=\"#bfdbfe\"/>\n<rect x=\"88\" y=\"185\" width=\"12\" height=\"20\" fill=\"#475569\"/><rect x=\"265\" y=\"185\" width=\"12\" height=\"20\" fill=\"#475569\"/>\n    <text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial,sans-serif\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Bett</text>\n    </svg>"}, {"word": "Blume", "example": "Die Blume steht in einer Vase.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><rect x=\"174\" y=\"95\" width=\"12\" height=\"90\" fill=\"#16a34a\"/><circle cx=\"180\" cy=\"70\" r=\"18\" fill=\"#facc15\"/><circle cx=\"150\" cy=\"70\" r=\"22\" fill=\"#f472b6\"/><circle cx=\"210\" cy=\"70\" r=\"22\" fill=\"#f472b6\"/><circle cx=\"180\" cy=\"42\" r=\"22\" fill=\"#f472b6\"/><circle cx=\"180\" cy=\"98\" r=\"22\" fill=\"#f472b6\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Blume</text></svg>"}, {"word": "Baum", "example": "Der Baum steht im Garten.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><rect x=\"165\" y=\"105\" width=\"30\" height=\"85\" fill=\"#92400e\"/><circle cx=\"180\" cy=\"85\" r=\"62\" fill=\"#22c55e\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Baum</text></svg>"}, {"word": "Sonne", "example": "Die Sonne scheint am Himmel.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><circle cx=\"180\" cy=\"110\" r=\"52\" fill=\"#facc15\"/><g stroke=\"#f59e0b\" stroke-width=\"9\"><line x1=\"180\" y1=\"25\" x2=\"180\" y2=\"45\"/><line x1=\"180\" y1=\"175\" x2=\"180\" y2=\"195\"/><line x1=\"95\" y1=\"110\" x2=\"115\" y2=\"110\"/><line x1=\"245\" y1=\"110\" x2=\"265\" y2=\"110\"/></g><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Sonne</text></svg>"}, {"word": "Wolke", "example": "Eine Wolke zieht über den Himmel.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><circle cx=\"135\" cy=\"125\" r=\"38\" fill=\"#cbd5e1\"/><circle cx=\"180\" cy=\"100\" r=\"50\" fill=\"#e2e8f0\"/><circle cx=\"225\" cy=\"125\" r=\"38\" fill=\"#cbd5e1\"/><rect x=\"130\" y=\"125\" width=\"100\" height=\"42\" rx=\"20\" fill=\"#cbd5e1\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Wolke</text></svg>"}, {"word": "Tisch", "example": "Der Tisch steht in der Küche.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><rect x=\"75\" y=\"90\" width=\"210\" height=\"28\" fill=\"#a16207\"/><rect x=\"95\" y=\"115\" width=\"18\" height=\"80\" fill=\"#78350f\"/><rect x=\"247\" y=\"115\" width=\"18\" height=\"80\" fill=\"#78350f\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Tisch</text></svg>"}, {"word": "Stuhl", "example": "Der Stuhl steht am Tisch.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><rect x=\"125\" y=\"65\" width=\"110\" height=\"85\" rx=\"12\" fill=\"#60a5fa\"/><rect x=\"125\" y=\"145\" width=\"110\" height=\"25\" fill=\"#2563eb\"/><rect x=\"140\" y=\"168\" width=\"16\" height=\"30\" fill=\"#334155\"/><rect x=\"204\" y=\"168\" width=\"16\" height=\"30\" fill=\"#334155\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Stuhl</text></svg>"}, {"word": "Jacke", "example": "Ich ziehe meine Jacke an.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><path d=\"M130 62 L160 45 H200 L230 62 L275 110 L245 140 L225 120 V195 H135 V120 L115 140 L85 110Z\" fill=\"#3b82f6\"/><line x1=\"180\" y1=\"48\" x2=\"180\" y2=\"195\" stroke=\"#dbeafe\" stroke-width=\"6\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Jacke</text></svg>"}, {"word": "Schuhe", "example": "Die Schuhe stehen vor der Tür.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><path d=\"M70 150 Q120 145 145 110 L180 145 Q170 175 115 180 H70Z\" fill=\"#475569\"/><path d=\"M180 150 Q230 145 255 110 L290 145 Q280 175 225 180 H180Z\" fill=\"#64748b\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Schuhe</text></svg>"}, {"word": "Uhr", "example": "Die Uhr hängt an der Wand.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><circle cx=\"180\" cy=\"115\" r=\"70\" fill=\"#fff\" stroke=\"#334155\" stroke-width=\"7\"/><line x1=\"180\" y1=\"115\" x2=\"180\" y2=\"70\" stroke=\"#334155\" stroke-width=\"8\"/><line x1=\"180\" y1=\"115\" x2=\"220\" y2=\"135\" stroke=\"#334155\" stroke-width=\"8\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Uhr</text></svg>"}, {"word": "Brille", "example": "Die Brille liegt auf dem Tisch.", "svg": "<svg viewBox=\"0 0 360 240\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"360\" height=\"240\" rx=\"26\" fill=\"#f8fafc\"/><circle cx=\"125\" cy=\"115\" r=\"45\" fill=\"none\" stroke=\"#111827\" stroke-width=\"8\"/><circle cx=\"235\" cy=\"115\" r=\"45\" fill=\"none\" stroke=\"#111827\" stroke-width=\"8\"/><line x1=\"170\" y1=\"115\" x2=\"190\" y2=\"115\" stroke=\"#111827\" stroke-width=\"8\"/><text x=\"180\" y=\"220\" text-anchor=\"middle\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\" fill=\"#1f2937\">Brille</text></svg>"}];let index=+(localStorage.wortfit_index||0)%items.length,done=+(localStorage.wortfit_done||0),good=+(localStorage.wortfit_good||0),timer;
const el=id=>document.getElementById(id);function show(id){document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));el(id).classList.add('active');scrollTo(0,0)}function norm(s){return s.toLowerCase().replace(/[.,!?;:]/g,' ').replace(/\s+/g,' ').trim()}function polish(s){s=s.trim().replace(/\s+/g,' ');if(!s)return'';s=s[0].toUpperCase()+s.slice(1);return/[.!?]$/.test(s)?s:s+'.'}const verbs=['bin','bist','ist','sind','war','waren','habe','hat','haben','geht','gehen','fahre','fährt','fahren','läuft','laufen','sitzt','stehen','steht','liegt','essen','esse','isst','trinke','trinkt','spielen','spielt','kauft','lesen','liest','fliegt','kommt','klingelt','wächst','zieht','scheint','hängt'];
function evalSentence(raw,target='',example=''){if(!raw.trim())return{ok:false,msg:'Bitte zuerst einen Satz schreiben oder sprechen.'};const t=norm(raw),w=t.split(' '),hasTarget=!target||t.includes(norm(target)),hasVerb=verbs.some(v=>w.includes(v))||w.some(x=>/(en|t|st)$/.test(x)&&x.length>3),long=w.length>=3,ok=hasTarget&&hasVerb&&long;let tips=[];if(!hasTarget)tips.push('Benutze das Wort „'+target+'“.');if(!hasVerb)tips.push('Füge ein Verb hinzu.');if(!long)tips.push('Der Satz darf etwas länger sein.');return ok?{ok:true,msg:'✅ Gut gemacht!<br><b>'+polish(raw)+'</b>'}:{ok:false,msg:'💡 Fast richtig. '+tips.join(' ')+(example?'<br><b>Vorschlag: '+example+'</b>':'')}}
function speakText(t){if(!('speechSynthesis'in window))return;const u=new SpeechSynthesisUtterance(t);u.lang='de-DE';u.rate=.9;speechSynthesis.cancel();speechSynthesis.speak(u)}function speechInto(area,fb){const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR){fb.textContent='Spracheingabe wird nicht unterstützt.';return}const r=new SR();r.lang='de-DE';fb.textContent='🎤 Ich höre zu ...';r.onresult=e=>{area.value=e.results[0][0].transcript;fb.textContent='Sprache erkannt. Jetzt prüfen.'};r.onerror=()=>fb.textContent='Nicht erkannt. Bitte noch einmal.';r.start()}
function render(){const i=items[index];el('image').innerHTML=i.svg;el('wordText').textContent=i.word;el('example').textContent='Beispiel: '+i.example;el('example').style.display='none';el('sentence').value='';el('count').textContent='Bereit';el('feedback').textContent='Drücke auf „Start“.';el('done').textContent=done;el('goodCount').textContent=good;localStorage.wortfit_index=index}
el('start').onclick=()=>{clearInterval(timer);document.getElementById('wordText').style.visibility='hidden';let n=+el('wait').value;el('count').textContent=n+' Sekunden';timer=setInterval(()=>{n--;if(n>0){el('count').textContent=n+' Sekunden';}else{clearInterval(timer);document.getElementById('wordText').style.visibility='visible';el('count').textContent='Jetzt Satz bilden';el('sentence').focus();}},1000)};el('exampleBtn').onclick=()=>el('example').style.display=el('example').style.display==='block'?'none':'block';el('speak').onclick=()=>speechInto(el('sentence'),el('feedback'));el('check').onclick=()=>{const r=evalSentence(el('sentence').value,items[index].word,items[index].example);done++;if(r.ok)good++;el('feedback').innerHTML=r.msg;localStorage.wortfit_done=done;localStorage.wortfit_good=good;el('done').textContent=done;el('goodCount').textContent=good};el('read').onclick=()=>speakText(el('sentence').value||items[index].example);el('next').onclick=()=>{index=(index+1)%items.length;render()};el('freeSpeak').onclick=()=>speechInto(el('freeSentence'),el('freeFeedback'));el('freeCheck').onclick=()=>el('freeFeedback').innerHTML=evalSentence(el('freeSentence').value).msg;el('freeRead').onclick=()=>speakText(el('freeSentence').value);el('freeClear').onclick=()=>{el('freeSentence').value='';el('freeFeedback').textContent='Bilde deinen eigenen Satz.'};render();
</script></body></html>
